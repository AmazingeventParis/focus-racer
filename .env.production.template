# Database
DB_PASSWORD=your_secure_postgres_password_here

# NextAuth
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=https://focusracer.swipego.app

# Stripe
STRIPE_SECRET_KEY=sk_live_or_test_key
STRIPE_PUBLISHABLE_KEY=pk_live_or_test_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
PLATFORM_FEE_PERCENT=10

# Email (Resend)
RESEND_API_KEY=re_your_resend_api_key
EMAIL_FROM=Focus Racer <noreply@focusracer.swipego.app>

# AWS Rekognition (IA : OCR dossards + reconnaissance faciale)
# Reste sur AWS meme apres migration du stockage vers OVH.
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA_YOUR_ACCESS_KEY_ID_HERE
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_ACCESS_KEY_HERE
AWS_REKOGNITION_COLLECTION_ID=focusracer-faces

# Object Storage (S3-compatible) — AWS S3 OU OVH Object Storage
# Si STORAGE_S3_* est vide, fallback automatique sur AWS_* (compat ascendante).
#
# --- Option A : AWS S3 (config actuelle) ---
# Laisser STORAGE_S3_ENDPOINT vide et renseigner seulement AWS_S3_BUCKET.
AWS_S3_BUCKET=your-s3-bucket-name
#
# --- Option B : OVH Object Storage (S3-compatible) ---
# Decommenter et renseigner pour basculer le stockage sur OVH.
# Endpoint selon la region OVH : gra (Gravelines), sbg (Strasbourg), rbx (Roubaix)...
# STORAGE_S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
# STORAGE_S3_REGION=gra
# STORAGE_S3_BUCKET=focusracer
# STORAGE_S3_ACCESS_KEY_ID=ovh_access_key
# STORAGE_S3_SECRET_ACCESS_KEY=ovh_secret_key
# STORAGE_S3_FORCE_PATH_STYLE=true
#
# URL publique/CDN servant les objets directement (optionnel). Vide = URLs presignees.
STORAGE_PUBLIC_URL=
# (AWS_CLOUDFRONT_URL reste lu en fallback de STORAGE_PUBLIC_URL)
AWS_CLOUDFRONT_URL=

# AI Configuration (optimized for 8-core server)
AI_OCR_CONFIDENCE_THRESHOLD=70
AI_QUALITY_THRESHOLD=30
AI_AUTO_EDIT_ENABLED=true
AI_FACE_INDEX_ENABLED=true
AI_LABEL_DETECTION_ENABLED=true
AI_MAX_CONCURRENT=8

# Cloudflare Turnstile (anti-bot CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=   # Cloudflare Turnstile site key
TURNSTILE_SECRET_KEY=              # Cloudflare Turnstile secret key

# Cron
CRON_SECRET=your_cron_secret_here
